{
  "name": "@lamalibre/portlama-gatekeeper",
  "version": "0.1.0",
  "description": "Authorization layer for Portlama — groups, grants, and tunnel access control",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "bin": {
    "portlama-gatekeeper": "dist/cli/index.js"
  },
  "files": [
